# Cloudflare D1 (wypełniane przez wrangler automatycznie)
# DATABASE_ID=your-d1-database-id

# Opcjonalne: Ambee Pollen API (https://www.ambeedata.com/)
AMBEE_API_KEY=

# Opcjonalne: Google Pollen API (wymagane billing)
GOOGLE_POLLEN_API_KEY=

# Cloudflare Pages deploy hook (do triggerowania rebuildu z GitHub Actions)
CF_PAGES_DEPLOY_HOOK=https://api.cloudflare.com/client/v4/pages/webhooks/deploy_hooks/YOUR_HOOK_ID

# GitHub Actions: Cloudflare API Token (do deployu)
CF_API_TOKEN=
CF_ACCOUNT_ID=
